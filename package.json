{
  "name": "shadow-en",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@shadow-en/web",
    "dev:mobile": "turbo dev --filter=@shadow-en/mobile",
    "build": "turbo build",
    "build:web": "turbo build --filter=@shadow-en/web",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}